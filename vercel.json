{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "**/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "**/*.css",
            "use": "@vercel/static"
        },
        {
            "src": "**/*.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "env": {
        "NEON_DATABASE_URL": "@NEON_DATABASE_URL",
        "EMAIL_SERVICE_API_KEY": "@EMAIL_SERVICE_API_KEY",
        "EMAIL_FROM": "@EMAIL_FROM",
        "ADMIN_EMAIL": "@ADMIN_EMAIL"
    }
}
