# Bobgo Shipping API Configuration
# ⚠️ IMPORTANT: This file is for LOCAL DEVELOPMENT only
# ⚠️ DO NOT commit this file with actual values to git!
#
# For production, add these variables in Vercel Dashboard:
# Settings → Environment Variables

# Bobgo API Key (Get from: https://my.bobgo.co.za/)
BOBGO_API_KEY=your_api_key_here

# Bobgo API Base URL
BOBGO_API_URL=https://api.bobgo.co.za/v1

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace 'your_api_key_here' with your actual API key
# 3. Run 'vercel dev' to test locally
# 4. For production, add variables in Vercel dashboard instead
